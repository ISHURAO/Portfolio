# ── MongoDB ────────────────────────────────────
# Local MongoDB (make sure mongod is running):
MONGO_URI=mongodb://localhost:27017/portfolio

# OR MongoDB Atlas (cloud, free tier):
# MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/portfolio

# ── Gmail (Nodemailer) ─────────────────────────
# HOW TO GET APP PASSWORD:
# 1. Go to myaccount.google.com
# 2. Security → Enable 2-Step Verification
# 3. Security → App Passwords → Create → Name it "Portfolio"
# 4. Copy the 16-char password below
EMAIL_USER=ishuy066@gmail.com
EMAIL_PASS=kyje vxbp mxqe nykf

# ── Admin Panel Token ─────────────────────────
# Change this to something secret!
ADMIN_TOKEN=ishu-admin-secret-2025

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development
